# ── 必填 ──────────────────────────────────────────────
# PostgreSQL 连接 (用于 LangGraph checkpointer + 任务持久化)
DATABASE_URL=postgresql+asyncpg://lms:lms_dev_2024@localhost:5432/localmodelstudio

# LLM API — 支持 OpenAI 或兼容 API (DeepSeek, 通义等)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek V4 (平行于 V3，如果启用 USE_DEEPSEEK_V4 则覆盖使用此配置)
USE_DEEPSEEK_V4=True
# DeepSeek Account 1 (主力)
DEEPSEEK_V4_API_KEY_1=sk-434b68b6b2c24df0bbf11cb6c6e98d05
# DeepSeek Account 2 (备用)
DEEPSEEK_V4_API_KEY_2=sk-64917c50db49481cb959f892b8c1ca82
# 当前使用哪个 key (1 或 2)
DEEPSEEK_ACTIVE_KEY=2
DEEPSEEK_V4_API_KEY=sk-64917c50db49481cb959f892b8c1ca82
DEEPSEEK_V4_API_BASE=https://api.deepseek.com
# ── 可选 ──────────────────────────────────────────────
# 自定义 API 端点 (不填则用 OpenAI 官方)
OPENAI_BASE_URL=https://api.openai.com/v1

# 节点 Agent 类型 (非 "claude_code" 则使用 LLM/DeepSeek)
CODE_AGENT_TYPE=deepseek

# 各节点独立配置 (格式：node=agent_type:timeout:effort:model, 逗号分隔)
# 未指定则使用 CODE_AGENT_TYPE 和角色默认模型
NODE_AGENT_CONFIG=github_trending=claude_code:500:medium,analyze_twitter=claude_code:300:medium

# 输出目录 (默认: 项目根目录/output/)
OUTPUT_DIR=

# HTTP 代理
HTTP_PROXY=
HTTPS_PROXY=

# Langfuse 本地追踪 (可选，用于 LLM 可观测性)
LANGFUSE_PUBLIC_KEY=pk-lf-test
LANGFUSE_SECRET_KEY=sk-lf-test
LANGFUSE_HOST=http://localhost:3000

# MiMo TTS (小米)
MIMO_API_KEY=sk-cgp84ksqzkrg7l5rvvdyw9ltl6zd93jjrmxqxifgs3hh6q5w
MIMO_TTS_VOICE=苏打

