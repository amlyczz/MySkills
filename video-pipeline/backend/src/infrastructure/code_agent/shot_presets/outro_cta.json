{
  "id": "outro_cta",
  "name": "结尾行动号召",
  "description": "Logo 浮现 + 行动号召按钮 + 结束语",
  "slots": {
    "headline": { "type": "string", "description": "结尾标语" },
    "ctaText": { "type": "string", "description": "CTA 按钮文字，如 'Star on GitHub'" },
    "bgType": { "type": "string", "description": "背景类型", "default": "dark-neon" }
  },
  "template": {
    "id": "outro",
    "type": "outro",
    "durationSec": 3,
    "narrativePhase": "resolution",
    "background": { "type": "{{bgType}}" },
    "elements": [
      {
        "id": "cta-headline",
        "type": "animated-text",
        "props": { "text": "{{headline}}", "fontSize": "48px", "fontWeight": "bold", "color": "theme.colors.primary" },
        "layout": { "align": "center", "y": "40%", "width": "80%" },
        "animation": { "type": "fade-up", "timeline": { "inSec": 0, "durationSec": 0.8 } }
      },
      {
        "id": "cta-button",
        "type": "cta-button",
        "props": { "text": "{{ctaText}}", "bgColor": "theme.colors.primary" },
        "layout": { "align": "center", "y": "60%", "width": "300px" },
        "animation": { "type": "scale-bounce", "timeline": { "inSec": 0.8, "durationSec": 0.6 }, "loop": { "type": "pulse", "durationInFrames": 60, "amplitude": 0.03 } }
      }
    ]
  }
}
