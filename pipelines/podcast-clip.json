{
  "name": "podcast-clip",
  "description": "从文案直接生成音频片段（无需视觉素材）",
  "version": "1.0",
  "processors": [
    { "id": "compose",  "type": "ScriptTimelineComposer" },
    { "id": "audio",    "type": "MediaGenerator" },
    { "id": "post",     "type": "PostProducer" }
  ],
  "edges": [
    { "from": "compose", "to": "audio" },
    { "from": "audio",   "to": "post" }
  ],
  "inputs": {
    "topic": { "type": "string", "description": "话题描述" }
  },
  "outputs": {
    "final.mp3": { "from": "post" }
  }
}
