{
  "version": "1",
  "defaults": {
    "image":  { "provider": "minimax", "model": "image-01" },
    "speech": { "provider": "minimax", "model": "speech-hd" },
    "music":  { "provider": "minimax", "model": "music-2.6" },
    "video":  { "provider": "minimax", "model": "MiniMax-Hailuo-2.3-Fast-6s-768p" },
    "specialized_text": { "provider": "minimax", "model": "MiniMax-M1" }
  },
  "providers": {
    "omnivoice": {
      "api_url": "http://localhost:3900",
      "models": {
        "speech": ["omnivoice-3"]
      }
    },
    "minimax": {
      "api_key_env": "MINIMAX_API_KEY",
      "base_url": "https://api.minimaxi.com/v1",
      "region": "cn",
      "models": {
        "image":  ["image-01"],
        "speech": ["speech-hd", "speech-basic"],
        "music":  ["music-2.5", "music-2.6"],
        "video":  ["MiniMax-Hailuo-2.3-Fast-6s-768p", "MiniMax-Hailuo-2.3-6s-768p"],
        "specialized_text": ["MiniMax-M1"]
      }
    },
    "deepseek": {
      "api_key_env": "DEEPSEEK_API_KEY",
      "base_url": "https://api.deepseek.com/v1",
      "models": {
        "specialized_text": ["deepseek-chat"]
      }
    }
  },
  "aliases": {
    "cover_image": {
      "capability": "image",
      "providers": [
        { "provider": "minimax", "model": "image-01" }
      ]
    },
    "thumbnail": {
      "capability": "image",
      "providers": [
        { "provider": "minimax", "model": "image-01" }
      ]
    },
    "voiceover": {
      "capability": "speech",
      "providers": [
        { "provider": "minimax", "model": "speech-hd" },
        { "provider": "omnivoice", "model": "omnivoice-3" }
      ]
    },
    "bgm": {
      "capability": "music",
      "providers": [
        { "provider": "minimax", "model": "music-2.6" }
      ]
    },
    "video_clip": {
      "capability": "video",
      "providers": [
        { "provider": "minimax", "model": "MiniMax-Hailuo-2.3-Fast-6s-768p" }
      ]
    },
    "poem_writer": {
      "capability": "specialized_text",
      "providers": [
        { "provider": "deepseek", "model": "deepseek-chat" },
        { "provider": "minimax", "model": "MiniMax-M1" }
      ]
    },
    "lyrics_writer": {
      "capability": "specialized_text",
      "providers": [
        { "provider": "deepseek", "model": "deepseek-chat" },
        { "provider": "minimax", "model": "MiniMax-M1" }
      ]
    }
  }
}
