{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://myskills/schemas/content.schema.json",
  "title": "Content JSON – Layer 0 output",
  "description": "Structured content for a GitHub repo video pipeline: repo info, script, covers, publish copy, source code insight.",
  "type": "object",
  "required": ["repo", "content", "script", "covers", "publish_copy", "meta"],
  "properties": {
    "repo": {
      "type": "object",
      "required": ["full_name", "url"],
      "properties": {
        "full_name": { "type": "string", "examples": ["owner/repo"] },
        "url": { "type": "string", "format": "uri" },
        "language": { "type": "string" },
        "stars": { "type": "integer", "minimum": 0 },
        "forks": { "type": "integer", "minimum": 0 },
        "topics": { "type": "array", "items": { "type": "string" } },
        "license": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "homepage": { "type": "string", "format": "uri" }
      }
    },
    "content": {
      "type": "object",
      "required": ["title", "tagline", "points"],
      "properties": {
        "title": { "type": "string", "description": "Repo short name" },
        "tagline": { "type": "string", "description": "One-sentence positioning" },
        "points": {
          "type": "array",
          "items": { "type": "string" },
          "description": "3-5 key features",
          "minItems": 1
        },
        "summary": { "type": "string", "description": "Closing reflection or outro hook" },
        "stats_text": { "type": "string", "description": "Human-readable growth stats (e.g. '854 Stars, 2 days old')" },
        "target_users": { "type": "string" },
        "domains": { "type": "string", "description": "Chinese classification tags, separated by 、" },
        "chartData": {
          "type": "array",
          "description": "Optional benchmark/comparison data for animated bar charts",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "number", "minimum": 0, "maximum": 100 },
              "previousValue": { "type": "number", "minimum": 0, "maximum": 100 }
            }
          }
        }
      }
    },
    "script": {
      "type": "object",
      "required": ["full_text", "segments", "total_duration_est"],
      "properties": {
        "full_text": { "type": "string" },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["text", "duration_est"],
            "properties": {
              "text": { "type": "string" },
              "duration_est": { "type": "number", "minimum": 0 }
            }
          }
        },
        "total_duration_est": { "type": "number", "minimum": 0 }
      }
    },
    "covers": {
      "type": "object",
      "required": ["3x4", "16x9"],
      "properties": {
        "3x4": {
          "type": "object",
          "required": ["prompt_zh", "prompt_en"],
          "properties": {
            "prompt_zh": { "type": "string" },
            "prompt_en": { "type": "string" }
          }
        },
        "16x9": {
          "type": "object",
          "required": ["prompt_zh", "prompt_en"],
          "properties": {
            "prompt_zh": { "type": "string" },
            "prompt_en": { "type": "string" }
          }
        }
      }
    },
    "publish_copy": {
      "type": "object",
      "required": ["titles", "body", "tags"],
      "properties": {
        "titles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["full", "short"],
            "properties": {
              "full": { "type": "string" },
              "short": { "type": "string" }
            }
          }
        },
        "body": { "type": "string", "description": "Unified publish copy, 100-200 chars" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "source_code_insight": {
      "type": "object",
      "properties": {
        "architecture": { "type": "string" },
        "patterns": { "type": "array", "items": { "type": "string" } },
        "highlights": { "type": "array", "items": { "type": "string" } },
        "api_style": { "type": "string" },
        "analyzed_files": { "type": "array", "items": { "type": "string" } },
        "total_files_analyzed": { "type": "integer", "minimum": 0 },
        "total_lines_analyzed": { "type": "integer", "minimum": 0 }
      }
    },
    "meta": {
      "type": "object",
      "required": ["generated_at", "source"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "enum": ["gh-trending", "manual", "gh-api"] }
      }
    }
  }
}
