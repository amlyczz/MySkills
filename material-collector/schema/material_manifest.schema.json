{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://myskills/schemas/material_manifest.schema.json",
  "title": "Material Manifest — Layer 1 output",
  "description": "All materials collected for a GitHub repo video pipeline. Each entry recorded with source metadata and capture details.",
  "type": "object",
  "required": ["version", "repo", "created_at", "materials"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["2"],
      "description": "Schema version. v2 adds source/capture/metadata fields per material."
    },
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "repo": {
      "type": "object",
      "required": ["full_name", "url"],
      "properties": {
        "full_name": { "type": "string", "examples": ["owner/repo"] },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when materials were collected"
    },
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "path"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^mat_[a-z]+_[0-9]{3}$",
            "description": "Unique material ID, e.g. 'mat_scroll_001'"
          },
          "type": {
            "type": "string",
            "enum": [
              "scroll_video",
              "link_video",
              "manual_video",
              "manual_image",
              "image",
              "extracted_video",
              "screenshot",
              "code_snippet",
              "source_code",
              "doc_page",
              "repo_tree",
              "repo_stats",
              "changelog",
              "social_proof",
              "comparison"
            ],
            "description": "Material type from the 15-type taxonomy"
          },
          "path": {
            "type": "string",
            "description": "Relative or absolute path to the material file"
          },
          "duration": {
            "type": ["number", "null"],
            "minimum": 0,
            "description": "Duration in seconds (video/audio types only)"
          },
          "speed": {
            "type": "number",
            "minimum": 0.1,
            "default": 1.0,
            "description": "Playback speed multiplier. 2.0 = 2x fast, 0.5 = half-speed slow-mo"
          },
          "dimensions": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 },
            "minItems": 2,
            "maxItems": 2,
            "description": "[width, height] for image/video types"
          },
          "file_size_kb": {
            "type": "number",
            "minimum": 0
          },
          "source": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "readme_embedded",
                  "readme_text",
                  "github_page",
                  "external_link",
                  "gh_api",
                  "gh_clone",
                  "playwright_download",
                  "playwright_screenshot",
                  "user_provided"
                ]
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "Original URL the material came from"
              },
              "original_url": {
                "type": "string",
                "format": "uri",
                "description": "Resolved original URL (e.g. GitHub camo → raw)"
              },
              "element_selector": {
                "type": "string",
                "description": "CSS selector used for screenshot/capture"
              },
              "section": {
                "type": "string",
                "description": "README section heading the material belongs to"
              },
              "line_number": {
                "type": "integer",
                "minimum": 1,
                "description": "Line number in README where material appears"
              }
            }
          },
          "capture": {
            "type": "object",
            "required": ["method", "timestamp"],
            "properties": {
              "method": {
                "type": "string",
                "enum": [
                  "playwright_download",
                  "playwright_screenshot",
                  "gh_api",
                  "gh_clone",
                  "user_provided"
                ]
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "duration_ms": {
                "type": "number",
                "minimum": 0,
                "description": "Time taken to capture/download"
              },
              "retries": {
                "type": "integer",
                "minimum": 0,
                "default": 0
              }
            }
          },
          "metadata": {
            "type": "object",
            "description": "Type-specific metadata",
            "properties": {
              "alt_text": {
                "type": "string",
                "description": "Image alt text (for image/photo types)"
              },
              "is_camo_url": {
                "type": "boolean",
                "description": "Whether the image URL was GitHub camo (for image types)"
              },
              "filter_reason": {
                "type": ["string", "null"],
                "description": "Reason if filtered out (null = included)"
              },
              "language": {
                "type": "string",
                "description": "Programming language (for code_snippet types)"
              },
              "highlight_score": {
                "type": "number",
                "description": "Relevance score for screenshot/code snippet selection"
              },
              "lines": {
                "type": "integer",
                "minimum": 0,
                "description": "Line count (for source_code/doc_page types)"
              },
              "module": {
                "type": "string",
                "description": "Module name (for source_code types)"
              },
              "conversion": {
                "type": "string",
                "description": "Conversion chain applied (e.g. 'gif→mp4', 'svg→png')"
              }
            }
          }
        }
      }
    }
  }
}
