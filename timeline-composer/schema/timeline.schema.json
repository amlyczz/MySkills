{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://myskills/schemas/timeline.schema.json",
  "title": "Timeline — Layer 2 output",
  "description": "Rendered segment timeline for the Remotion video composer. Includes voiceover splits, material references, layout/motion directives, audio orchestration, chapter markers, and subtitles.",
  "type": "object",
  "required": ["version", "repo", "global", "segments", "chapters"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["2"],
      "description": "Schema version"
    },
    "repo": {
      "type": "object",
      "required": ["full_name", "url"],
      "properties": {
        "full_name": { "type": "string", "examples": ["owner/repo"] },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "global": {
      "type": "object",
      "required": ["title", "total_duration", "resolution", "fps"],
      "properties": {
        "title": { "type": "string", "description": "Main title displayed in intro/outro" },
        "total_duration": { "type": "number", "minimum": 0 },
        "resolution": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2,
          "description": "[width, height] e.g. [1920, 1080]"
        },
        "fps": { "type": "integer", "minimum": 1, "default": 30 },
        "bgm_track": { "type": "string", "description": "BGM track identifier (e.g. 'bgm_ambient_tech')" },
        "bgm_volume": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.2 },
        "progress_bar_style": {
          "type": "string",
          "enum": ["minimal-dots", "labeled-bar", "gradient-fill", "segment-blocks", "timeline-ticks"],
          "description": "Chapter progress bar visual style"
        }
      }
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "time_start", "time_end", "duration"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^seg_[0-9]{3}$",
            "description": "Segment ID, e.g. 'seg_001'"
          },
          "type": {
            "type": "string",
            "enum": [
              "hook",
              "problem",
              "solution",
              "features",
              "showcase",
              "code_showcase",
              "source_highlight",
              "stats_showcase",
              "proof",
              "changelog_showcase",
              "social_proof",
              "comparison",
              "cta",
              "manual"
            ],
            "description": "Segment type — determines template selection in Layer 3"
          },
          "label": {
            "type": "string",
            "description": "Human-readable segment label (e.g. '开篇', '核心功能')"
          },
          "time_start": { "type": "number", "minimum": 0 },
          "time_end": { "type": "number", "minimum": 0 },
          "duration": { "type": "number", "minimum": 0 },
          "voiceover": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "duration_est": { "type": "number", "minimum": 0 },
              "splits": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["text", "time_offset"],
                  "properties": {
                    "text": { "type": "string" },
                    "time_offset": { "type": "number", "minimum": 0 }
                  }
                }
              }
            }
          },
          "primary_material": {
            "type": ["string", "null"],
            "description": "Material ID of the primary visual (e.g. 'mat_scroll_001')"
          },
          "material_refs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "All material IDs referenced in this segment"
          },
          "material_time_range": {
            "type": "object",
            "description": "Trim range into a material (for scroll_video/link_video)",
            "properties": {
              "start": { "type": "number" },
              "end": { "type": "number" }
            }
          },
          "layout": {
            "type": "object",
            "required": ["layout_id"],
            "properties": {
              "layout_id": {
                "type": "string",
                "enum": [
                  "hero-center",
                  "split-left-text",
                  "media-full",
                  "card-grid",
                  "code-display",
                  "stat-highlight",
                  "quote-style"
                ]
              },
              "motion_map": {
                "type": "object",
                "description": "Motion config per element (headline, cards, title, etc.)",
                "additionalProperties": { "type": "string" }
              }
            }
          },
          "style": {
            "type": "object",
            "properties": {
              "theme_id": { "type": "string" },
              "bg_type": {
                "type": "string",
                "enum": ["starfield", "bokeh", "geometric", "pixel"]
              }
            }
          },
          "code_template": {
            "type": ["object", "null"],
            "description": "Code rendering config (for code_showcase / source_highlight types)",
            "properties": {
              "language": { "type": "string", "description": "e.g. 'bash', 'python', 'typescript'" },
              "highlight_lines": {
                "type": "array",
                "items": { "type": "integer", "minimum": 1 }
              },
              "animation": {
                "type": "string",
                "enum": ["type", "fade", "scroll"]
              },
              "show_line_numbers": { "type": "boolean" },
              "max_visible_lines": { "type": "integer", "minimum": 1 }
            }
          },
          "audio": {
            "type": "object",
            "properties": {
              "bgm_volume": { "type": "number", "minimum": 0, "maximum": 1 },
              "bgm_fade_in": { "type": "number", "minimum": 0, "description": "Fade-in duration in seconds" },
              "bgm_fade_out": { "type": "number", "minimum": 0, "description": "Fade-out duration in seconds" },
              "sfx": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "time"],
                  "properties": {
                    "id": { "type": "string" },
                    "time": { "type": "number", "minimum": 0 },
                    "volume": { "type": "number", "minimum": 0, "maximum": 1 },
                    "repeat_every": { "type": "number", "minimum": 0, "description": "Repeat interval for continuous SFX" }
                  }
                }
              }
            }
          },
          "transition_in": {
            "type": "string",
            "enum": ["fade", "dissolve", "slide-left", "slide-right", "none"]
          },
          "transition_out": {
            "type": "string",
            "enum": ["fade", "dissolve", "slide-left", "slide-right", "none"]
          }
        }
      }
    },
    "chapters": {
      "type": "array",
      "description": "Chapter markers for progress bar overlay",
      "items": {
        "type": "object",
        "required": ["label", "time"],
        "properties": {
          "label": { "type": "string" },
          "time": { "type": "number", "minimum": 0 }
        }
      }
    },
    "subtitles": {
      "type": "array",
      "description": "SRT-compatible subtitle entries (optional)",
      "items": {
        "type": "object",
        "required": ["text", "time_start", "time_end"],
        "properties": {
          "text": { "type": "string" },
          "time_start": { "type": "number", "minimum": 0 },
          "time_end": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
